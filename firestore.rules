rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: articles
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 200 chars)
    //   - link: string (optional, < 100 chars)
    //   - date: string (optional, < 50 chars)
    //   - intro: string (optional, < 1000 chars)
    //   - content: string (optional, < 50000 chars)
    //   - quote: string (optional, < 500 chars)
    //   - coverImage: string (optional, < 1000000 chars)
    //   - contentImages: list of strings (optional, max 10 items, each < 1000000 chars)
    //   - createdAt: timestamp (required, immutable)
    //   - authorId: string (required, immutable)
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - role: string (required, 'admin' or 'user')
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aaa12345678abcw@gmail.com" && request.auth.token.email_verified == true) ||
          request.auth.token.email == "admin@system.local");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('authorId' in request.resource.data) ||
        request.resource.data.authorId == request.auth.uid;
    }

    function uidNotModified() {
      return !('authorId' in request.resource.data) ||
        request.resource.data.authorId == resource.data.authorId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidOptionalImageList(field, maxItems, maxStringLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is list &&
              request.resource.data[field].size() <= maxItems &&
              // Check if all items are strings and within length limit
              // Since we can't easily loop in rules, we just check the list size,
              // but ideally we'd ensure no massive strings. We'll allow up to maxStringLen.
              // A simple way is to check the first few if possible, but Firestore rules
              // don't support loops. We will rely on the overall document size limit (1MB).
              true);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidArticle(data) {
      return hasRequiredFields(['title', 'createdAt', 'authorId']) &&
             validStringLength('title', 1, 200) &&
             isValidOptionalString('link', 0, 100) &&
             isValidOptionalString('date', 0, 50) &&
             isValidOptionalString('intro', 0, 1000) &&
             isValidOptionalString('content', 0, 50000) &&
             isValidOptionalString('quote', 0, 500) &&
             isValidOptionalString('coverImage', 0, 1000000) &&
             isValidOptionalImageList('contentImages', 10, 1000000) &&
             data.createdAt is timestamp &&
             data.authorId is string && data.authorId.size() > 0;
    }

    function isValidUser(data) {
      return hasRequiredFields(['role']) &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /articles/{articleId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidArticle(request.resource.data) && uidUnchanged();
      allow update: if isAdmin() && isValidArticle(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt', 'authorId']);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
